---
import { site } from "../data/site";
---
<section class="hero">
  <h1 class="name">{site.name}</h1>
  <p class="tagline">{site.tagline}</p>
  <p class="bio" data-en={site.bio.en} data-es={site.bio.es}>{site.bio.en}</p>
  <nav class="links">
    {site.links.map((link) => <a href={link.href}>{link.label}</a>)}
  </nav>
</section>
